# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set ONE key below. GEMINI_API_KEY takes priority if both are present.
#
# Option A: Google Gemini  (recommended — very low cost)
#   Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
#
# Option B: Anthropic Claude
#   Get key: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Model override (optional) ─────────────────────────────────────────────────
# Default for Gemini:    gemini-2.5-flash-lite
# Default for Anthropic: claude-sonnet-4-6
# LLM_MODEL=gemini-2.5-flash-lite

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3333

# ── Knowledge Base Location (optional) ───────────────────────────────────────
# By default, The Curator looks for a "domains" folder inside the app directory.
# Set DOMAINS_PATH to an absolute path if your wiki lives somewhere else —
# for example a dedicated folder that has its own private GitHub sync repo.
#
# Examples:
#   DOMAINS_PATH=/Users/yourname/Documents/my-brain
#   DOMAINS_PATH=/Users/yourname/Dropbox/curator-wiki
#
# Leave commented out to use the default ./domains folder.
# DOMAINS_PATH=

# ── Sync (set automatically by the Sync tab — do not edit manually) ───────────
# These are written by the app when you configure sync via the UI.
# GITHUB_SYNC_REPO and token are stored in .sync-config.json (gitignored).
